# ── DB (외부 PostgreSQL 서버) ─────────────────────────────────────────────
DB_HOST=192.168.0.103
DB_PORT=5432
POSTGRES_USER=linker
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# ── Monitoring ────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password

# ── Spring Boot (onprem 프로파일) ─────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars_long_here
ENCRYPTION_KEY=change_me_64hex_chars_aes256_key_here_0000000000000000000000

# ── CORS ──────────────────────────────────────────────────────────────────
# 프론트엔드가 접근하는 주소 (서버 IP 또는 도메인)
CORS_ALLOWED_ORIGINS=http://192.168.1.57

# ── 외부 API ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

NICE_API_URL=https://nice.checkplus.co.kr
NICE_CLIENT_ID=
