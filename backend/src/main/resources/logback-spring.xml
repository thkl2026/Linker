<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <!-- Loki 연동 Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app":"${appName}"}</customFields>
            <!-- Rule 1: 타임스탬프는 LogstashEncoder가 자동 포함 -->
        </encoder>
    </appender>

    <!-- 로컬 개발 환경 파일 로그 -->
    <springProfile name="local">
        <appender name="FILE_LOCAL" class="ch.qos.logback.core.FileAppender">
            <file>app-local.log</file>
            <append>false</append>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
    </springProfile>

    <!-- 운영 환경에서는 파일 롤링 추가 -->
    <springProfile name="onprem,cloud">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/linker.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/linker.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <timeBasedFileNamingAndTriggeringPolicy
                        class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                    <maxFileSize>100MB</maxFileSize>
                </timeBasedFileNamingAndTriggeringPolicy>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
        </appender>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="FILE_LOCAL"/>
        </root>
    </springProfile>

    <springProfile name="onprem,cloud">
        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <logger name="kr.co.linker" level="DEBUG"/>
    <logger name="org.springframework.security" level="INFO"/>
    <logger name="org.flywaydb" level="INFO"/>
    <!-- 느린 쿼리 감지 (100ms 초과 — Rule 1) -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql" level="TRACE"/>
</configuration>
